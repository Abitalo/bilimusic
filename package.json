{
  "name": "bilimusic",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop Bilibili music player built with Electron, React, and Vite.",
  "author": "BiliMusic Contributors",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "lint": "eslint .",
    "verify": "npm run lint && npx tsc -b --pretty false",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.bilimusic.app",
    "productName": "BiliMusic",
    "directories": {
      "output": "release/${version}",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!release{,/**}",
      "!src{,/**}",
      "!shared{,/**}",
      "!assets{,/**}",
      "!build{,/**}",
      "!public{,/**}",
      "!*.md"
    ],
    "icon": "build/icons/icon.png",
    "mac": {
      "category": "public.app-category.music",
      "icon": "build/icons/icon.png"
    },
    "win": {
      "icon": "build/icons/icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "axios": "^1.13.6",
    "electron-store": "^11.0.2",
    "lucide-react": "^0.577.0",
    "md5": "^2.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/md5": "^2.3.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.1.12",
    "vite-plugin-electron": "^0.29.0"
  }
}
